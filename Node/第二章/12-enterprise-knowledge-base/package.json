{
	"name": "enterprise-knowledge-base",
	"private": true,
	"version": "1.0.0",
	"workspaces": [
		"server",
		"web"
	],
	"scripts": {
		"dev": "concurrently -n server,web -c blue,green \"npm run start:dev -w server\" \"npm run dev -w web\"",
		"build": "npm run build -w server && npm run build -w web",
		"test": "npm run test -w server",
		"seed": "npm run seed -w server",
		"doctor": "node --env-file-if-exists=server/.env scripts/doctor.mjs"
	},
	"devDependencies": {
		"concurrently": "^9.2.1"
	},
	"engines": {
		"node": ">=22.12.0"
	},
	"overrides": {
		"multer": "2.2.0"
	}
}
